<Window x:Class="contact_liq.EditContactDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Contact"
        Width="480"
        Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFBE3F0"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFB04A7A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFF5B6CF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FFF5B6CF"/>
            <Setter Property="Foreground" Value="#FFB04A7A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE89ABF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Background="#FFFFFF"
            CornerRadius="12"
            Margin="24"
            Padding="32"
            BorderBrush="#FFF5B6CF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Direction="270"
                              ShadowDepth="4"
                              BlurRadius="10"
                              Opacity="0.05"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,24"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#FFE06AA7"
                       Text="{Binding DialogTitle}" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="First Name" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditableContact.FirstName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Last Name" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditableContact.LastName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Email Address" Margin="0,0,0,4"/>
                <TextBox Text="{Binding EditableContact.Email, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Age" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditableContact.Age, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="City" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditableContact.City, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Category ID" Margin="0,0,0,4"/>
                <TextBox Text="{Binding EditableContact.CategoryId, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="1=Friends, 2=Family, 3=Work"/>
            </StackPanel>

            <StackPanel Grid.Row="6"
                        Margin="0,24,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Width="100"
                        Margin="0,0,12,0"
                        Content="Save"
                        Click="OkButton_Click"
                        Style="{StaticResource ModernButton}" />

                <Button Width="100"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Background="#FFD67AA8"
                        Foreground="#FFB04A7A">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFC45A90" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
