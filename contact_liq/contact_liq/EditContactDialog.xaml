<Window x:Class="contact_liq.EditContactDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Contact"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Margin="0,0,0,12"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding DialogTitle}" />

        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="First name" />
        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Margin="8,4"
                 Text="{Binding EditableContact.FirstName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Last name" />
        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Margin="8,4"
                 Text="{Binding EditableContact.LastName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Email" />
        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 Margin="8,4"
                 Text="{Binding EditableContact.Email, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="Age" />
        <TextBox Grid.Row="4"
                 Grid.Column="1"
                 Margin="8,4"
                 Text="{Binding EditableContact.Age, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="5" VerticalAlignment="Center" Text="City" />
        <TextBox Grid.Row="5"
                 Grid.Column="1"
                 Margin="8,4"
                 VerticalAlignment="Top"
                 Text="{Binding EditableContact.City, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="6"
                    Grid.ColumnSpan="2"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="90" Margin="0,0,8,0" Content="Save" Click="OkButton_Click" />
            <Button Width="90" Content="Cancel" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
