<Window x:Class="contact_liq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:contact_liq"
        mc:Ignorable="d"
        Title="Contacts"
        Width="1120"
        Height="760"
        MinWidth="960"
        MinHeight="640">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="18" Background="#FFFDECF4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Contacts" Foreground="#FFE06AA7" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#FFF2A7C8"
                       Text="Create, edit, delete, and inspect people with data binding and LINQ operations." />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0" Padding="14" Background="#FFFCE3EE" CornerRadius="10" BorderBrush="#FFF5B6CF" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Filter and Sort" Foreground="#FFE06AA7" />
                    <TextBlock Margin="0,12,0,4" Text="Filter" Foreground="#FFD86A9A" />
                    <ComboBox ItemsSource="{Binding FilterOptions}" SelectedItem="{Binding SelectedFilter}" Background="#FFFFFF" />
                    <TextBlock Margin="0,12,0,4" Text="Filter value" Foreground="#FFD86A9A" />
                    <TextBox Text="{Binding FilterValue, UpdateSourceTrigger=PropertyChanged}" Background="#FFFFFF" />
                    <TextBlock Margin="0,12,0,4" Text="Sort" Foreground="#FFD86A9A" />
                    <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" Background="#FFFFFF" />
                    <Button Margin="0,14,0,0"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Command="{Binding ApplyFiltersCommand}"
                            Content="Refresh results"
                            Background="#FFF5B6CF"
                            Foreground="#FFB04A7A"
                            BorderBrush="#FFE89ABF">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,0,12,0" Padding="14" Background="#FFFCE3EE" CornerRadius="10" BorderBrush="#FFF5B6CF" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Projection" Foreground="#FFE06AA7" />
                    <TextBlock Margin="0,12,0,4" Text="Transformation method" Foreground="#FFD86A9A" />
                    <ComboBox ItemsSource="{Binding ProjectionOptions}" SelectedItem="{Binding SelectedProjection}" Background="#FFFFFF" />
                    <TextBlock Margin="0,12,0,8" FontWeight="SemiBold" Text="Result" Foreground="#FFD86A9A" />
                    <TextBox MinHeight="140"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding ProjectionResult, Mode=OneWay}"
                             Background="#FFFFFF"
                             BorderBrush="#FFF5B6CF" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="14" Background="#FFFCE3EE" CornerRadius="10" BorderBrush="#FFF5B6CF" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Checks and Aggregation" Foreground="#FFE06AA7" />
                    <TextBlock Margin="0,12,0,4" Text="Quantifier" Foreground="#FFD86A9A" />
                    <ComboBox ItemsSource="{Binding QuantifierOptions}" SelectedItem="{Binding SelectedQuantifier}" Background="#FFFFFF" />
                    <TextBlock Margin="0,8,0,12" FontWeight="SemiBold" Text="{Binding QuantifierResult, Mode=OneWay}" Foreground="#FFE06AA7" />
                    <TextBlock Margin="0,0,0,4" Text="Aggregation" Foreground="#FFD86A9A" />
                    <ComboBox ItemsSource="{Binding AggregationOptions}" SelectedItem="{Binding SelectedAggregation}" Background="#FFFFFF" />
                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="{Binding AggregationResult, Mode=OneWay}" Foreground="#FFE06AA7" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="14" Background="White" BorderBrush="#FFF5C9DA" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Left" FontSize="18" FontWeight="SemiBold" Text="People" Foreground="#FFE06AA7" />
                </DockPanel>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          ItemsSource="{Binding FilteredContacts}"
                          SelectedItem="{Binding SelectedContact}"
                          SelectionMode="Single"
                          Background="White"
                          BorderBrush="#FFF5C9DA"
                          RowBackground="#FFFDECF4"
                          AlternatingRowBackground="#FFFBE3F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="60" Binding="{Binding Id}" Header="Id" />
                        <DataGridTextColumn Width="*" Binding="{Binding FirstName}" Header="First name" />
                        <DataGridTextColumn Width="*" Binding="{Binding LastName}" Header="Last name" />
                        <DataGridTextColumn Width="2*" Binding="{Binding Email}" Header="Email" />
                        <DataGridTextColumn Width="80" Binding="{Binding Age}" Header="Age" />
                        <DataGridTextColumn Width="*" Binding="{Binding City}" Header="City" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Margin="0,12,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="110" Margin="0,0,8,0" Padding="10,6" 
                            Command="{Binding AddCommand}" 
                            Content="Add"
                            Background="#FFF5B6CF"
                            Foreground="#FFB04A7A"
                            BorderBrush="#FFE89ABF">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Width="110" Margin="0,0,8,0" Padding="10,6" 
                            Command="{Binding EditCommand}" 
                            Content="Edit"
                            Background="#FFF5B6CF"
                            Foreground="#FFB04A7A"
                            BorderBrush="#FFE89ABF">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Width="110" Padding="10,6" 
                            Command="{Binding DeleteCommand}" 
                            Content="Delete"
                            Background="#FFF5B6CF"
                            Foreground="#FFB04A7A"
                            BorderBrush="#FFE89ABF">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
