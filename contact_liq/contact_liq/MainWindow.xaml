<Window x:Class="contact_liq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:contact_liq"
        mc:Ignorable="d"
        Title="Contacts Manager"
        Width="1200"
        Height="800"
        MinWidth="1000"
        MinHeight="660"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Window.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFDECF4"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFF5B6CF"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="10" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FFF5B6CF"/>
            <Setter Property="Foreground" Value="#FFB04A7A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE89ABF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFD67AA8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFB04A7A"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFD86A9A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFF5B6CF"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFF5B6CF"/>
        </Style>

    </Window.Resources>

    <Grid Background="#FFFBE3F0" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="36" FontWeight="Bold" Text="Contacts Management" Foreground="#FFE06AA7" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="16"
                       Foreground="#FFD86A9A"
                       Text="Advanced LINQ operations, EF Core bindings, and fully-featured CRUD for people." />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Filter and Sort" Margin="0,0,0,16" Foreground="#FFE06AA7" />
                    <Label Content="Filtering Criterion" />
                    <ComboBox ItemsSource="{Binding FilterOptions}" SelectedItem="{Binding SelectedFilter}" />
                    <Label Content="Filter Value" />
                    <TextBox Text="{Binding FilterValue, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Sorting Order" />
                    <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" />
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ApplyFiltersCommand}"
                            Content="Refresh Results"
                            Style="{StaticResource ModernButton}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Data Projection" Margin="0,0,0,16" Foreground="#FFE06AA7" />
                    <Label Content="Transformation Method" />
                    <ComboBox ItemsSource="{Binding ProjectionOptions}" SelectedItem="{Binding SelectedProjection}" />
                    <Label Content="Result Output" Margin="0,8,0,4" />
                    <TextBox MinHeight="130"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding ProjectionResult, Mode=OneWay}"
                             FontFamily="Consolas"
                             Background="#FFFFFF" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Insights &amp; Analytics" Margin="0,0,0,16" Foreground="#FFE06AA7" />
                    <Label Content="Quantifier / Checking Rule" />
                    <ComboBox ItemsSource="{Binding QuantifierOptions}" SelectedItem="{Binding SelectedQuantifier}" />
                    <Border Background="#FFFCE3EE" BorderBrush="#FFF5B6CF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                        <TextBlock FontWeight="Bold" Text="{Binding QuantifierResult, Mode=OneWay}" Foreground="#FFB04A7A" HorizontalAlignment="Center" FontSize="16" />
                    </Border>
                    <Label Content="Aggregation Strategy" />
                    <ComboBox ItemsSource="{Binding AggregationOptions}" SelectedItem="{Binding SelectedAggregation}" />
                    <Border Background="#FFFDECF4" BorderBrush="#FFF5B6CF" BorderThickness="1" CornerRadius="6" Padding="12">
                        <TextBlock FontWeight="Bold" Text="{Binding AggregationResult, Mode=OneWay}" Foreground="#FFB04A7A" HorizontalAlignment="Center" FontSize="16" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock DockPanel.Dock="Left" FontSize="20" FontWeight="Bold" Text="People Database" Foreground="#FFE06AA7" />
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding StatusMessage}" Foreground="#FFB04A7A" FontWeight="SemiBold" />
                </DockPanel>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          ItemsSource="{Binding FilteredContacts}"
                          SelectedItem="{Binding SelectedContact}"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderBrush="#FFF5B6CF"
                          BorderThickness="1"
                          RowHeight="40"
                          RowBackground="#FFFFFF"
                          AlternatingRowBackground="#FFFBE3F0"
                          HorizontalGridLinesBrush="#FFF5B6CF"
                          VerticalGridLinesBrush="#FFF5B6CF">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFFDECF4" />
                            <Setter Property="Foreground" Value="#FFB04A7A" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="BorderBrush" Value="#FFF5B6CF" />
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFFCE3EE" />
                                    <Setter Property="Foreground" Value="#FFB04A7A" />
                                    <Setter Property="BorderBrush" Value="#00000000" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Width="60" Binding="{Binding Id}" Header="ID" />
                        <DataGridTextColumn Width="1.5*" Binding="{Binding FirstName}" Header="First Name" />
                        <DataGridTextColumn Width="1.5*" Binding="{Binding LastName}" Header="Last Name" />
                        <DataGridTextColumn Width="2*" Binding="{Binding Email}" Header="Email Address" />
                        <DataGridTextColumn Width="80" Binding="{Binding Age}" Header="Age" />
                        <DataGridTextColumn Width="1.2*" Binding="{Binding City}" Header="City" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Margin="0,20,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Width="120" Margin="0,0,12,0"
                            Command="{Binding AddCommand}"
                            Content="Add Contact"
                            Style="{StaticResource ModernButton}" />

                    <Button Width="120" Margin="0,0,12,0"
                            Command="{Binding EditCommand}"
                            Content="Edit Selected"
                            Background="#FFE89ABF"
                            Foreground="#FFB04A7A">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFD67AA8" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="120"
                            Command="{Binding DeleteCommand}"
                            Content="Delete Contact"
                            Background="#FFD67AA8"
                            Foreground="#FFB04A7A">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFC45A90" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
