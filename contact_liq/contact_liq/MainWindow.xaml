<Window x:Class="contact_liq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:contact_liq"
        mc:Ignorable="d"
        Title="Contact List" Height="500" Width="750"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <local:ProjectionConverter x:Key="ProjectionConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Contact List" FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <!-- Main content: list on the left, form on the right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Contact ListBox -->
            <ListBox x:Name="ContactListBox" Grid.Column="0" Margin="0,0,5,0"
                     SelectionChanged="ContactListBox_SelectionChanged"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="★" Foreground="Gold" FontSize="14" Margin="0,0,5,0"
                                       Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Separator -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="LightGray"/>

            <!-- Details / Edit Form -->
            <Border Grid.Column="2" Margin="5,0,0,0" Padding="10"
                    BorderBrush="LightGray" BorderThickness="1" CornerRadius="5">
                <StackPanel x:Name="EditPanel">
                    <TextBlock Text="Contact Details" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Name:" Margin="0,5,0,2"/>
                    <TextBox x:Name="NameTextBox" />

                    <TextBlock Text="Phone:" Margin="0,10,0,2"/>
                    <TextBox x:Name="PhoneTextBox" />

                    <TextBlock Text="Email:" Margin="0,10,0,2"/>
                    <TextBox x:Name="EmailTextBox" />

                    <CheckBox x:Name="FavoriteCheckBox" Content="Mark as Favorite"
                              Margin="0,12,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0"
                                HorizontalAlignment="Center">
                        <Button x:Name="SaveButton" Content="Save" Width="80"
                                Margin="0,0,10,0" Click="SaveButton_Click"/>
                        <Button x:Name="CancelButton" Content="Cancel" Width="80"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0"
                    HorizontalAlignment="Center">
            <Button x:Name="AddButton" Content="Add Contact" Width="110"
                    Margin="0,0,10,0" Click="AddButton_Click"/>
            <Button x:Name="DeleteButton" Content="Delete Contact" Width="110"
                    Margin="0,0,10,0" Click="DeleteButton_Click"/>
            <Button x:Name="ToggleFavoriteButton" Content="Toggle Favorite" Width="110"
                    Click="ToggleFavoriteButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
